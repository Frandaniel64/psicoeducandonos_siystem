# Copiar a .env y rellenar (no commitear .env con secretos reales)

PORT=3000

# Obligatorio. Mínimo 16 caracteres en desarrollo; en producción mínimo 32.
# Generar ejemplo: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
JWT_SECRET=

# Opcional en desarrollo (por defecto se permiten http://localhost:4200 y 127.0.0.1:4200).
# En producción (NODE_ENV=production) es obligatorio: URL(s) del front, separadas por coma.
# FRONTEND_ORIGIN=https://app.tudominio.com,https://staging.tudominio.com

NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DATABASE=psicoeducandonos_db
