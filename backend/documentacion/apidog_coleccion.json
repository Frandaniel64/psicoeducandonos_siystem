{
  "openapi": "3.0.0",
  "info": {
    "title": "API Psicoeducándonos",
    "version": "1.0.0",
    "description": "Colección de Endpoints separando Staff de Pacientes. (Listo para ApiDog)"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/v1/auth/staff/login": {
      "post": {
        "tags": [
          "Autenticación (Staff)"
        ],
        "summary": "Login Doctores/Admins",
        "description": "Valida credenciales contra la tabla Users y devuelve un JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "doctor@psicoeducandonos.org"
                  },
                  "password": {
                    "type": "string",
                    "example": "123456"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Login Correcto",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas"
          }
        }
      }
    },
    "/api/v1/auth/patient/login": {
      "post": {
        "tags": [
          "Autenticación (Pacientes)"
        ],
        "summary": "Login Clientes Públicos",
        "description": "Valida credenciales contra la tabla separada Patient y devuelve un JWT de acceso limitado",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "paciente@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "secreta123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Login Correcto"
          }
        }
      }
    }
  }
}
